// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MEMBER
  RECRUITER
  ADMIN
}

enum MemberCategory {
  SUPER30
  SCHOOL
}

enum DeletedMemberKind {
  WHITELIST
  RECRUITER
}

model WhitelistEmail {
  id        String          @id @default(cuid())
  email     String          @unique
  category  MemberCategory  @default(SCHOOL)
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@map("whitelist_emails")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  role      UserRole  @default(MEMBER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  profile          Profile?
  recruiterAccount RecruiterAccount?
  bookmarksGiven   Bookmark[]        @relation("RecruiterBookmarks")

  @@map("users")
}

model Profile {
  id              String         @id @default(cuid())
  userId          String         @unique
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName        String
  username        String         @unique
  phone           String?
  phonePublic     Boolean        @default(false)
  avatar          String?
  age             Int?
  city            String?
  country         String?
  about           String?
  currentCompany  String?
  hasJobOffers    Boolean        @default(false)
  jobOffersDesc   String?
  jobUrl          String?        // NEW: Website or job link
  salaryRange     String?        // NEW: Expected budget
  jobLocation     String?        // NEW: Remote / On-site / Hybrid
  activelyLooking Boolean        @default(false)
  resumeUrl       String?        // URL of uploaded PDF resume from Cloudinary
  resumeFilename  String?        // Original filename of resume
  atsScore        Int?           // Score out of 100 generated by Gemini
  atsFeedback     String?        // Text feedback generated by Gemini
  techStack       String[]       @default([])
  skills          String[]       @default([])
  interests       String[]       @default([])
  portfolioUrl    String?
  githubUrl       String?
  twitterUrl      String?
  linkedinUrl     String?
  category        MemberCategory @default(SCHOOL)
  isComplete      Boolean        @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookmarksReceived Bookmark[] @relation("ProfileBookmarks")
  aiTags            AiTag?

  @@map("profiles")
}

model RecruiterAccount {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String
  website     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("recruiter_accounts")
}

model OtpToken {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@map("otp_tokens")
}

model Bookmark {
  id          String   @id @default(cuid())
  recruiterId String
  recruiter   User     @relation("RecruiterBookmarks", fields: [recruiterId], references: [id], onDelete: Cascade)
  profileId   String
  profile     Profile  @relation("ProfileBookmarks", fields: [profileId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([recruiterId, profileId])
  @@map("bookmarks")
}

model AiTag {
  id        String   @id @default(cuid())
  profileId String   @unique
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  tags      String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_tags")
}

model DeletedMemberLog {
  id                 String            @id @default(cuid())
  kind               DeletedMemberKind
  deletedEmail       String
  deletedName        String?
  deletedUsername    String?
  deletedCategory    MemberCategory?
  deletedCompanyName String?
  deletedWebsite     String?
  deletedByEmail     String
  deletedAt          DateTime          @default(now())

  @@index([deletedAt])
  @@map("deleted_member_logs")
}
